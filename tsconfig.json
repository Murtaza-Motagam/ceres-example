{
  "compilerOptions": {
    "target": "ESNext", // Keep modern for tree-shaking; Babel will downlevel to ES5
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {},
    "noEmit": true,
  },
  "include": [
    "src",
    "tests"
  ]
}